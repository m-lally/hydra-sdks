{
  "name": "@hydra-payments/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for Hydra Payment Service — HMAC-signed client, types, React & Vue integration",
  "license": "MIT",
  "author": "Hydra Payments",
  "homepage": "https://github.com/hydra-payments/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hydra-payments/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/hydra-payments/sdk/issues"
  },
  "keywords": [
    "hydra",
    "payments",
    "sdk",
    "api-client",
    "typescript",
    "payment-gateway",
    "hmac"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "require": "./dist/react/index.js",
      "import": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "require": "./dist/vue/index.js",
      "import": "./dist/vue/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test src/__tests__/",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "axios": "^1.6.7"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.3.3",
    "vue": "^3.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
